{% extends 'base.html.twig' %}

{% block title %}Clients sous gestion{% endblock %}

{% block body %}
<h1>Clients sous gestion</h1>

<style>
    .clients-table-sort th a {
        color: inherit;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-weight: 600;
    }
    .clients-table-sort th a:hover { text-decoration: underline; }
    .clients-table-sort .sort-arrows { font-size: 0.75em; opacity: 0.85; letter-spacing: -0.05em; }
    .clients-table-sort .sort-inactive { opacity: 0.45; font-weight: 400; }
    .clients-table-sort .data-sheet__group td {
        padding: 0.55rem 0.75rem;
        border-top: 1px solid var(--table-border);
        border-bottom: 1px solid var(--table-border);
    }
</style>

<table class="clients-table-sort data-sheet">
    <thead>
        <tr>
            <th style="padding: 0.75rem; text-align: left;">
                <a href="{{ path('app_clients_table', {sort: 'client', dir: sort == 'client' and dir == 'asc' ? 'desc' : 'asc'}) }}">
                    Client
                    <span class="sort-arrows">{% if sort == 'client' %}{{ dir == 'asc' ? '▲' : '▼' }}{% else %}<span class="sort-inactive">⇅</span>{% endif %}</span>
                </a>
            </th>
            <th style="padding: 0.75rem; text-align: left;">
                <a href="{{ path('app_clients_table', {sort: 'cm', dir: sort == 'cm' and dir == 'asc' ? 'desc' : 'asc'}) }}">
                    Community Manager
                    <span class="sort-arrows">{% if sort == 'cm' %}{{ dir == 'asc' ? '▲' : '▼' }}{% else %}<span class="sort-inactive">⇅</span>{% endif %}</span>
                </a>
            </th>
            <th style="padding: 0.75rem; text-align: left;">
                <a href="{{ path('app_clients_table', {sort: 'monteur', dir: sort == 'monteur' and dir == 'asc' ? 'desc' : 'asc'}) }}">
                    Monteur
                    <span class="sort-arrows">{% if sort == 'monteur' %}{{ dir == 'asc' ? '▲' : '▼' }}{% else %}<span class="sort-inactive">⇅</span>{% endif %}</span>
                </a>
            </th>
            <th style="padding: 0.75rem; text-align: left;">Actions</th>
        </tr>
    </thead>
    <tbody>
        {% set lastGroup = null %}
        {% for client in clients %}
            {% set groupValue = null %}
            {% if sort == 'cm' %}
                {% set groupValue = client.communityManager ? client.communityManager.name : '—' %}
            {% elseif sort == 'monteur' %}
                {% set groupValue = client.editor ? client.editor.name : '—' %}
            {% endif %}

            {% if groupValue is not null and groupValue != lastGroup %}
                <tr class="data-sheet__group">
                    <td colspan="4">
                        <small>{{ sort == 'cm' ? 'CM' : 'Monteur' }}</small>
                        {{ groupValue }}
                    </td>
                </tr>
                {% set lastGroup = groupValue %}
            {% endif %}

            <tr>
                <td style="padding: 0.75rem;"><a href="{{ path('app_client_show', {id: client.id}) }}">{{ client.name }}</a></td>
                <td style="padding: 0.75rem;">{{ client.communityManager ? client.communityManager.name : '—' }}</td>
                <td style="padding: 0.75rem;">{{ client.editor ? client.editor.name : '—' }}</td>
                <td style="padding: 0.75rem;"><a href="{{ path('app_client_show', {id: client.id}) }}" class="btn btn-sm">Voir</a></td>
            </tr>
        {% else %}
            <tr><td colspan="4" style="padding: 1rem; color: var(--muted);">Aucun client. <a href="{{ path('app_admin_client_new') }}">Ajouter un client</a></td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
