{% extends 'base.html.twig' %}

{% block title %}{{ communityManager.id ? 'Modifier' : 'Nouveau' }} Community Manager{% endblock %}

{% block body %}
<h1>{{ communityManager.id ? 'Modifier' : 'Nouveau' }} Community Manager</h1>
<p><a href="{{ path('app_admin_cm_index') }}">← Retour</a></p>

<form method="post">
    <label for="name">Nom</label>
    <input type="text" id="name" name="name" value="{{ communityManager.name }}" required>
    <label for="email">Email</label>
    <input type="email" id="email" name="email" value="{{ communityManager.email }}" required>
    <label for="password">Mot de passe {{ communityManager.id ? '(laisser vide pour ne pas changer)' : '' }}</label>
    <input type="password" id="password" name="password" {{ communityManager.id ? '' : 'required' }}>
    <button type="submit" class="btn">Enregistrer</button>
</form>
{% endblock %}
