<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rapport montages — {{ client.name }} | Osmose</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #0b1220;
            --muted: #334155;
            --border: #d7dee8;
            --card: #ffffff;
            --accent: #5b21b6;
            --accent-2: #2f1b5f;
            --frame: #6b7280;
            --row-odd: #ffffff;
            --row-alt: #eceff3;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: system-ui, -apple-system, "Public Sans", sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 9pt;
            font-weight: 400;
        }
        .wrap { max-width: 1040px; margin: 0 auto; padding: 8px 10px 14px; }
        .sheet {
            border: 0;
            border-radius: 0;
            padding: 0;
        }
        .header {
            background: #f3f4f6;
            color: var(--text);
            border-radius: 10px;
            padding: 8px 10px;
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 10px;
            align-items: center;
            border: 1px solid var(--frame);
        }
        .header img {
            width: 150px;
            height: auto;
            object-fit: contain;
            /* Violet + noir depuis le logo blanc: rendu propre sur fond clair */
            filter: brightness(0) saturate(100%) invert(18%) sepia(78%) saturate(3550%) hue-rotate(262deg) brightness(88%) contrast(110%);
        }
        .header h1 { margin: 0; font-size: 10pt; letter-spacing: 0.2px; font-weight: 600; }
        .header .meta { margin-top: 3px; display: grid; gap: 1px; color: #111827; font-size: 8.5pt; }
        .header .meta strong { font-weight: 600; }

        .card { margin-top: 6px; background: var(--card); border: 0; padding: 0; }
        .subtle { color: var(--muted); font-size: 8.5pt; }

        table {
            width: 100%;
            table-layout: fixed;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 12px;
            border: 1px solid var(--frame);
        }
        thead th {
            background: #f8fafc;
            color: var(--text);
            font-size: 7.5pt;
            text-align: left;
            vertical-align: bottom;
            padding: 5px 8px 6px;
            border-bottom: 1px solid var(--frame);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-weight: 600;
            line-height: 1.15;
        }
        tbody td {
            padding: 5px 8px 6px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
            font-size: 8.5pt;
            font-weight: 400;
            line-height: 1.22;
        }
        tbody tr:nth-child(odd) td { background: var(--row-odd); }
        tbody tr:nth-child(even) td { background: var(--row-alt); }
        .col-title {
            font-weight: 500;
            line-height: 1.22;
        }
        /* pre-wrap sur le <td> conservait les retours à la ligne du source HTML → ligne vide en haut */
        .col-notes {
            font-size: 8.5pt;
            color: var(--text);
            line-height: 1.22;
            white-space: normal;
            word-break: break-word;
            vertical-align: top;
            min-width: 9em;
        }
        .col-notes__text {
            margin: 0;
            padding: 0;
            color: var(--text);
            line-height: 1.22;
            white-space: pre-line;
            word-break: break-word;
        }
        .col-notes__block { margin: 0; }
        .col-notes__sep {
            margin: 2px 0;
            border: 0;
            border-top: 1px solid var(--border);
            height: 0;
        }
        .col-notes__section-h {
            display: block;
            font-size: 6.5pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--accent);
            margin: 0 0 2px;
            line-height: 1.15;
        }
        .col-notes__cmt { margin-top: 5px; }
        .col-notes__cmt:first-child { margin-top: 0; }
        .col-notes__cmt-meta {
            display: block;
            font-size: 7pt;
            color: var(--frame);
            margin-bottom: 2px;
        }
        .col-notes__cmt-msg {
            font-size: 8.5pt;
            color: var(--text);
            line-height: 1.22;
            white-space: pre-line;
            word-break: break-word;
        }
        .badge {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 999px;
            border: 1px solid var(--frame);
            background: #f9fafb;
            font-size: 7.5pt;
            color: #0b1220;
            font-weight: 500;
            line-height: 1.2;
            vertical-align: top;
        }
        .td-stat { vertical-align: top; white-space: nowrap; }
        .xcell {
            text-align: center;
            width: 56px;
            max-width: 56px;
            white-space: nowrap;
            font-weight: 600;
            color: #111827;
            letter-spacing: 0;
            vertical-align: top;
        }
        thead th.xcell {
            font-size: 7pt;
            padding-left: 4px;
            padding-right: 4px;
            text-align: center;
        }
        td.xcell { padding-top: 5px; padding-bottom: 5px; line-height: 1; }
        /* Marqueurs sobres : noir sur blanc (meilleur rendu impression / PDF que fond violet + X blanc) */
        .xcell .x {
            display: inline-block;
            min-width: 0.55em;
            font-size: 10pt;
            font-weight: 800;
            line-height: 1;
            color: #cbd5e1;
            vertical-align: baseline;
        }
        .xcell .x.on {
            color: #0f172a;
        }
        .footer {
            margin-top: 12px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            color: var(--muted);
            font-size: 8pt;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }
        .report-note {
            margin: 5px 0 6px;
            padding: 6px 10px;
            border: 1px solid var(--frame);
            border-radius: 8px;
            background: #fafafa;
            font-size: 8.5pt;
            line-height: 1.35;
            color: var(--text);
        }
        .report-note strong {
            display: block;
            font-size: 8pt;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--accent);
            margin-bottom: 3px;
        }
        .report-note .report-note-body {
            white-space: pre-line;
            word-break: break-word;
        }

        @page {
            margin: 10mm 12mm;
        }

        @media print {
            body { background: #fff; }
            .wrap { padding: 5mm 6mm; }
            .sheet { border: 0; border-radius: 0; padding: 0; }
            .header { box-shadow: none; border-radius: 0; border: 1px solid #6b7280; padding: 5mm 6mm; }
            .card { border: 0; padding: 0; }
            .footer { display: none; }
            thead { display: table-header-group; }
            tbody tr:nth-child(even) td {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
<div class="wrap">
    <div class="sheet">
    <div class="header">
        <div>
            <img src="{{ absolute_url(asset('logo-site-blanc.svg')) }}" alt="Osmose">
        </div>
        <div>
            <h1>Point de situation des montages</h1>
            <div class="meta">
                <div><strong>Client :</strong> {{ client.name }}</div>
                <div><strong>Généré par :</strong> {{ generatedBy }}</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="subtle" style="margin-bottom: 4px;">
            {{ items|length }} vidéo(s) — {{ periodLabel }}.
        </div>

        {% if reportNote is defined and reportNote|trim != '' %}
            <div class="report-note">
                <strong>Note</strong>
                <div class="report-note-body">{{ reportNote|e }}</div>
            </div>
        {% endif %}

        <table>
            <thead>
            <tr>
                <th style="width: 30%;">Vidéo</th>
                <th style="width: 26%;">Note interne</th>
                <th style="width: 15%;">Statut</th>
                {% for stage in stages %}
                    <th class="xcell">{{ stage.label }}</th>
                {% endfor %}
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                {% set statusName = item.status ? item.status.name : '' %}
                {% set noteText = item.notes|default('')|trim %}
                <tr>
                    <td class="col-title">{{ item.title }}</td>
                    <td class="col-notes">{%- if noteText != '' -%}
                            <div class="col-notes__text">{{ noteText|e }}</div>
                        {%- endif -%}
                        {%- if item.comments is not empty -%}
                            {%- if noteText != '' -%}<hr class="col-notes__sep">{%- endif -%}
                            <div class="col-notes__block">
                                <span class="col-notes__section-h">Retours équipe</span>
                                {%- for c in item.comments -%}
                                    <div class="col-notes__cmt">
                                        <span class="col-notes__cmt-meta">{{ (c.author ? c.author.name : '—')|e }} · {{ c.createdAt|date('d/m/Y H:i') }}</span>
                                        <div class="col-notes__cmt-msg">{{ c.message|e }}</div>
                                    </div>
                                {%- endfor -%}
                            </div>
                        {%- endif -%}
                        {%- if noteText == '' and item.comments is empty -%}
                            —
                        {%- endif -%}
                    </td>
                    <td class="td-stat"><span class="badge">{{ statusName ?: '—' }}</span></td>
                    {% for stage in stages %}
                        {% set isOn = stage.doneIfIn is defined ? (statusName in stage.doneIfIn) : (statusName not in stage.doneIfNotIn) %}
                        <td class="xcell"><span class="x {{ isOn ? 'on' : '' }}">{{ isOn ? 'X' : '·' }}</span></td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ 3 + (stages|length) }}" style="padding: 14px; color: var(--muted);">
                        Aucune vidéo trouvée pour cette période.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="footer">
            <div>Outil de gestion de contenu — Osmose Marketing</div>
            <div>État au : {{ generatedAt|date('d.m.Y') }}</div>
        </div>
    </div>
    </div>
</div>
</body>
</html>

