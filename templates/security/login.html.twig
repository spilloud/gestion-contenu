<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion | Gestion des contenus</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap');
        body {
            font-family: "Public Sans", system-ui, sans-serif;
            margin: 0;
            padding: 2rem;
            background: linear-gradient(135deg, #140b2e, #1c1040 55%, #3b1c78);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .login-box {
            background: rgba(255,255,255,0.98);
            padding: 2rem;
            border-radius: 14px;
            box-shadow: 0 24px 40px rgba(2, 6, 23, 0.35);
            max-width: 430px;
            width: 100%;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 1.2rem;
        }
        .logo img { width: 170px; object-fit: contain; }
        .logo strong { font-size: 1rem; color: #0f172a; }
        h1 { margin-top: 0; margin-bottom: 1rem; font-size: 1.35rem; }
        .flash-success {
            background: #ecfdf3;
            color: #166534;
            border: 1px solid #bbf7d0;
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            font-size: 0.9rem;
        }
        label { display: block; margin-bottom: 0.35rem; font-weight: 600; color: #334155; }
        input {
            width: 100%;
            padding: 0.66rem;
            margin-bottom: 1rem;
            border: 1px solid #dbe1ea;
            border-radius: 8px;
            font-size: 0.95rem;
        }
        button {
            width: 100%;
            padding: 0.78rem;
            background: #5b21b6;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 0.96rem;
            font-weight: 600;
            cursor: pointer;
        }
        button:hover { background: #4c1d95; }
        a { color: #5b21b6; }
        .error {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <div class="login-box">
        <div class="logo">
            <img src="{{ asset('logo-login-noir-violet.svg') }}" alt="Logo Osmose Marketing">
        </div>
        <h1>Connexion</h1>
        {% for message in app.flashes('success') %}
            <div class="flash-success">{{ message }}</div>
        {% endfor %}
        {% if error %}
            <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}
        <form method="post" action="{{ path('app_login') }}">
            <label for="username">Email</label>
            <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="email" required autofocus>
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="_password" autocomplete="current-password" required>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <input type="hidden" name="_remember_me" value="on">
            <button type="submit">Se connecter</button>
        </form>
        <p style="margin-top: 1rem; text-align: center; font-size: 0.9rem;">
            <a href="{{ path('app_forgot_password_request') }}" style="color: #5b21b6; font-weight: 600;">Mot de passe oublié ?</a>
        </p>
    </div>
</body>
</html>
