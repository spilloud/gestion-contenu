<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rapport montages — {{ client.name }} | Osmose</title>
    <style>
        :root {
            --bg: #ffffff;
            --text: #0b1220;
            --muted: #334155;
            --border: #d7dee8;
            --card: #ffffff;
            --accent: #5b21b6;
            --accent-2: #2f1b5f;
            --frame: #6b7280;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: system-ui, -apple-system, "Public Sans", sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 9pt;
            font-weight: 400;
        }
        .wrap { max-width: 1040px; margin: 0 auto; padding: 14px 12px 24px; }
        .sheet {
            border: 0;
            border-radius: 0;
            padding: 0;
        }
        .header {
            background: #f3f4f6;
            color: var(--text);
            border-radius: 14px;
            padding: 14px 14px;
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 14px;
            align-items: center;
            border: 1px solid var(--frame);
        }
        .header img {
            width: 170px;
            height: auto;
            object-fit: contain;
            /* Violet + noir depuis le logo blanc: rendu propre sur fond clair */
            filter: brightness(0) saturate(100%) invert(18%) sepia(78%) saturate(3550%) hue-rotate(262deg) brightness(88%) contrast(110%);
        }
        .header h1 { margin: 0; font-size: 10pt; letter-spacing: 0.2px; font-weight: 600; }
        .header .meta { margin-top: 6px; display: grid; gap: 2px; color: #111827; font-size: 8.5pt; }
        .header .meta strong { font-weight: 600; }

        .card { margin-top: 12px; background: var(--card); border: 0; padding: 0; }
        .subtle { color: var(--muted); font-size: 8.5pt; }

        table {
            width: 100%;
            table-layout: fixed;
            border-collapse: collapse;
            overflow: hidden;
            border-radius: 12px;
            border: 1px solid var(--frame);
        }
        thead th {
            background: #f8fafc;
            color: var(--text);
            font-size: 7.5pt;
            text-align: left;
            vertical-align: top;
            padding: 5px 7px 6px;
            border-bottom: 1px solid var(--frame);
            text-transform: uppercase;
            letter-spacing: 0.04em;
            font-weight: 600;
            line-height: 1.15;
        }
        thead th.th-notes {
            background: linear-gradient(180deg, #f4f0ff 0%, #f8fafc 55%);
            border-left: 3px solid var(--accent);
            padding-left: 10px;
            text-transform: none;
            letter-spacing: 0;
        }
        .th-notes__line {
            display: block;
            line-height: 1.2;
            white-space: normal;
        }
        .th-notes__title {
            font-size: 8.5pt;
            font-weight: 700;
            color: var(--accent-2);
            letter-spacing: 0.01em;
        }
        .th-notes__sub {
            font-size: 7pt;
            font-weight: 600;
            color: var(--muted);
            letter-spacing: 0.02em;
        }
        tbody td {
            padding: 3px 7px 4px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
            font-size: 8.5pt;
            font-weight: 400;
            line-height: 1.2;
        }
        tbody tr:nth-child(2n) td { background: #fbfdff; }
        .col-title {
            font-weight: 500;
            line-height: 1.2;
        }
        .col-notes {
            font-size: 8pt;
            color: var(--text);
            line-height: 1.2;
            white-space: pre-wrap;
            word-break: break-word;
            vertical-align: top;
            min-width: 9em;
            border-left: 3px solid #ede9fe;
            padding-left: 10px;
        }
        tbody tr:nth-child(2n) td.col-notes { background: #faf8ff; }
        .col-notes__text { margin: 0; padding: 0; color: var(--text); line-height: 1.2; }
        .col-notes__block { margin: 0; }
        .col-notes__sep {
            margin: 4px 0;
            border: 0;
            border-top: 1px solid var(--border);
            height: 0;
        }
        .col-notes__section-h {
            display: block;
            font-size: 6.5pt;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--accent);
            margin: 0 0 2px;
            line-height: 1.15;
        }
        .col-notes__cmt { margin-top: 4px; }
        .col-notes__cmt:first-child { margin-top: 0; }
        .col-notes__cmt-meta {
            display: block;
            font-size: 7pt;
            color: var(--frame);
            margin-bottom: 2px;
        }
        .col-notes__cmt-msg { font-size: 8pt; color: var(--text); line-height: 1.2; }
        .badge {
            display: inline-block;
            padding: 1px 6px;
            border-radius: 999px;
            border: 1px solid var(--frame);
            background: #f9fafb;
            font-size: 7.5pt;
            color: #0b1220;
            font-weight: 500;
            line-height: 1.2;
            vertical-align: baseline;
        }
        .td-stat { vertical-align: top; white-space: nowrap; }
        .xcell {
            text-align: center;
            width: 72px;
            max-width: 72px;
            white-space: nowrap;
            font-weight: 800;
            color: #111827;
            letter-spacing: 0.04em;
            vertical-align: top;
        }
        thead th.xcell { font-size: 7pt; padding-left: 4px; padding-right: 4px; }
        td.xcell { padding-top: 3px; padding-bottom: 3px; }
        .xcell .x {
            display: inline-block;
            width: 15px;
            height: 15px;
            border-radius: 4px;
            border: 1px solid var(--border);
            line-height: 15px;
            font-size: 8pt;
            vertical-align: top;
        }
        .xcell .x.on { background: var(--accent); border-color: var(--accent); color: #fff; }
        .footer {
            margin-top: 12px;
            display: flex;
            justify-content: space-between;
            gap: 10px;
            color: var(--muted);
            font-size: 8pt;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }
        .report-note {
            margin: 12px 0 14px;
            padding: 10px 12px;
            border: 1px solid var(--frame);
            border-radius: 10px;
            background: #fafafa;
            font-size: 8.5pt;
            line-height: 1.45;
            color: var(--text);
        }
        .report-note strong {
            display: block;
            font-size: 8pt;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--accent);
            margin-bottom: 6px;
        }
        .report-note .report-note-body {
            white-space: pre-wrap;
            word-break: break-word;
        }

        @page {
            margin: 14mm;
        }

        @media print {
            body { background: #fff; }
            .wrap { padding: 8mm; }
            .sheet { border: 0; border-radius: 0; padding: 0; }
            .header { box-shadow: none; border-radius: 0; border: 1px solid #6b7280; }
            .card { border: 0; padding: 0; }
            .footer { display: none; }
            thead { display: table-header-group; }
            thead th.th-notes {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            tbody tr:nth-child(2n) td.col-notes {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
<div class="wrap">
    <div class="sheet">
    <div class="header">
        <div>
            <img src="{{ absolute_url(asset('logo-site-blanc.svg')) }}" alt="Osmose">
        </div>
        <div>
            <h1>Point de situation des montages</h1>
            <div class="meta">
                <div><strong>Client :</strong> {{ client.name }}</div>
                <div><strong>Généré par :</strong> {{ generatedBy }}</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="subtle" style="margin-bottom: 10px;">
            {{ items|length }} vidéo(s) — {{ periodLabel }}.
        </div>

        {% if reportNote is defined and reportNote|trim != '' %}
            <div class="report-note">
                <strong>Note</strong>
                <div class="report-note-body">{{ reportNote|e }}</div>
            </div>
        {% endif %}

        <table>
            <thead>
            <tr>
                <th style="width: 30%;">Vidéo</th>
                <th class="th-notes" style="width: 26%;">
                    <span class="th-notes__line">
                        <span class="th-notes__title">Note interne</span><span class="th-notes__sub"> — fiche &amp; retours</span>
                    </span>
                </th>
                <th style="width: 15%;">Statut</th>
                {% for stage in stages %}
                    <th class="xcell">{{ stage.label }}</th>
                {% endfor %}
            </tr>
            </thead>
            <tbody>
            {% for item in items %}
                {% set statusName = item.status ? item.status.name : '' %}
                <tr>
                    <td class="col-title">{{ item.title }}</td>
                    <td class="col-notes">
                        {% set noteText = item.notes|default('')|trim %}
                        {% if noteText != '' %}
                            <div class="col-notes__text">{{ noteText|e }}</div>
                        {% endif %}
                        {% if item.comments is not empty %}
                            {% if noteText != '' %}<hr class="col-notes__sep">{% endif %}
                            <div class="col-notes__block">
                                <span class="col-notes__section-h">Retours équipe</span>
                                {% for c in item.comments %}
                                    <div class="col-notes__cmt">
                                        <span class="col-notes__cmt-meta">{{ (c.author ? c.author.name : '—')|e }} · {{ c.createdAt|date('d/m/Y H:i') }}</span>
                                        <div class="col-notes__cmt-msg">{{ c.message|e }}</div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {% if noteText == '' and item.comments is empty %}
                            —
                        {% endif %}
                    </td>
                    <td class="td-stat"><span class="badge">{{ statusName ?: '—' }}</span></td>
                    {% for stage in stages %}
                        {% set isOn = stage.doneIfIn is defined ? (statusName in stage.doneIfIn) : (statusName not in stage.doneIfNotIn) %}
                        <td class="xcell">
                            <span class="x {{ isOn ? 'on' : '' }}">{{ isOn ? 'X' : '' }}</span>
                        </td>
                    {% endfor %}
                </tr>
            {% else %}
                <tr>
                    <td colspan="{{ 3 + (stages|length) }}" style="padding: 14px; color: var(--muted);">
                        Aucune vidéo trouvée pour cette période.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <div class="footer">
            <div>Outil de gestion de contenu — Osmose Marketing</div>
            <div>État au : {{ generatedAt|date('d.m.Y') }}</div>
        </div>
    </div>
    </div>
</div>
</body>
</html>

