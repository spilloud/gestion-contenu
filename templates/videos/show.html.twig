{% extends 'base.html.twig' %}

{% block title %}Vidéo — {{ content.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        {% include 'content/_workflow_fiche_styles.html.twig' %}
    </style>
{% endblock %}

{% block body %}
{% set status_name = content.status ? content.status.name : '' %}
{% set status_hints = {
    'Tournage à prévoir': 'Planification : la CM saisit le titre et la date pour organiser le tournage. Après le tournage et le dépôt des rushs, lancez le montage.',
    'Brouillon (Dérush)': 'Ancienne étape — utilisez « Demande de montage » ou la page Dérush.',
    'Rushs / à dispatcher': 'Ancienne étape — utilisez « Demande de montage » ou la page Dérush.',
    'Montage à faire': 'Le monteur travaille sur la tâche Asana. Quand c’est prêt : « Montage terminé » ou « Demande de retouches ».',
    'Montage en cours': 'Le monteur travaille sur la tâche Asana. Quand c’est prêt : « Montage terminé » ou « Demande de retouches ».',
    'Retouches (Monteur)': 'Retouches en cours. Puis « Montage terminé ».',
    'À valider (Prod)': 'Validation prod : choisissez avec ou sans sous-titres.',
    'Sous-titrage (SubMagic)': 'SubMagic en cours — puis « Sous-titres à valider (CM) ».',
    'Prépa CM (sans sous-titres)': 'Préparation CM — puis validation CM.',
    'Sous-titres à valider': 'La CM relit et valide les sous-titres.',
    'À valider (CM)': 'Validation CM — puis envoi au client.',
    'À valider (Client)': 'En attente du retour client.',
    'À faire valider au client': 'En attente du retour client.',
    'Prête à programmer': 'Validée — prête pour le calendrier.',
    'Programmée': 'Programmée — publiez quand c’est en ligne.',
    'Publiée': 'Vidéo publiée.',
} %}
{% set status_hint = status_hints[status_name]|default('Utilisez le bouton principal ci-dessous pour faire avancer le projet.') %}
{% set return_to_val = returnTo|default(path('app_videos_index')) %}

<div class="content-fiche">
    <nav class="content-fiche__topnav" aria-label="Navigation">
        <a href="{{ return_to_val }}">← Retour</a>
        <span aria-hidden="true" style="color: var(--card-border);">·</span>
        <a href="{{ path('app_calendar', {formats: [content.format.id], month: content.scheduledDate|date('n'), year: content.scheduledDate|date('Y')}) }}">Calendrier</a>
        <span aria-hidden="true" style="color: var(--card-border);">·</span>
        <a href="#vw-journal">Journal</a>
        <span aria-hidden="true" style="color: var(--card-border);">·</span>
        <a href="#bloc-equipe">Équipe</a>
        <span aria-hidden="true" style="color: var(--card-border);">·</span>
        <a href="#bloc-fichiers">Fichiers</a>
        <span aria-hidden="true" style="color: var(--card-border);">·</span>
        <a href="#retours-discussion">Retours</a>
    </nav>

    <header class="content-fiche__title-bar">
        <h1>{{ content.title }}</h1>
        <div class="content-fiche__meta-chips">
            <span>{{ content.client.name }}</span>
            <span>Pub. <strong>{{ content.scheduledDate|date('d/m/Y') }}</strong></span>
            <span>Montage <strong>{{ content.asanaMontageDueOn ? content.asanaMontageDueOn|date('d/m/Y') : '—' }}</strong></span>
            <span>Monteur <strong>{{ content.videoEditor ? content.videoEditor.name : '—' }}</strong></span>
            <span>CM <strong>{{ cm_display_name }}</strong></span>
            <span>Sous-titres <strong>{{ content.videoHasSubtitles ? 'Oui' : 'Non' }}</strong></span>
        </div>
    </header>

    <div class="content-fiche__layout">
        {% include 'content/_workflow_hero.html.twig' with {
            return_to: return_to_val,
            status_hint: status_hint,
            status_name: status_name,
            manual_settings_label: 'Réglages & pilotage manuel',
        } %}
        {% include 'content/_workflow_journal.html.twig' %}

        <div class="content-fiche__form-col">
            {{ form_start(form) }}
            <input type="hidden" name="_return_to" value="{{ return_to_val }}">

            <section id="bloc-equipe" class="content-fiche__section">
                <div class="content-fiche__section-head">
                    <h2>Équipe</h2>
                    <span class="content-fiche__section-kicker">Asana</span>
                </div>
                <p class="vf-team-hint">Enregistrer réassigne automatiquement les tâches Asana (montage et relecture sous-titres) si elles existent. La sync automatique tourne aussi toutes les 15&nbsp;min.</p>
                <form method="post" action="{{ path('app_video_asana_sync', {id: content.id}) }}" class="vf-asana-sync-form" style="margin-bottom: 1rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('asana_sync' ~ content.id) }}">
                    <input type="hidden" name="_return_to" value="{{ return_to_val }}">
                    <button type="submit" class="vw-btn vw-btn--ghost">↻ Rafraîchir depuis Asana</button>
                </form>
                <div class="vf-team-grid">
                    {{ form_row(form.videoEditor) }}
                    {{ form_row(form.videoCommunityManager) }}
                </div>
            </section>

            <section id="bloc-fichiers" class="content-fiche__section">
                <div class="content-fiche__section-head">
                    <h2>Fichiers & liens</h2>
                    <span class="content-fiche__section-kicker">KDrive · SubMagic</span>
                </div>

                {% include 'videos/_link_field.html.twig' with {
                    label: 'Rushs',
                    form_field: form.videoRushesUrl,
                    initial_url: content.videoRushesUrl,
                } %}
                {% include 'videos/_link_field.html.twig' with {
                    label: 'SubMagic',
                    form_field: form.videoSubmagicUrl,
                    initial_url: content.videoSubmagicUrl,
                } %}
                {% include 'videos/_link_field.html.twig' with {
                    label: 'Final',
                    form_field: form.videoFinalUrl,
                    initial_url: content.videoFinalUrl,
                } %}

                <div class="content-fiche__hidden-fields" aria-hidden="true">
                    {{ form_widget(form.videoEditUrl) }}
                    {{ form_widget(form.videoEditFilename) }}
                    {{ form_widget(form.videoFinalFilename) }}
                    {{ form_widget(form.videoThumbnailUrl) }}
                </div>
            </section>

            <section id="bloc-texte" class="content-fiche__section">
                <div class="content-fiche__section-head">
                    <h2>Notes & légende</h2>
                </div>
                {{ form_row(form.notes) }}
                {{ form_row(form.videoCaption) }}
            </section>

            <details class="content-fiche__details" id="bloc-pilotage">
                <summary>Réglages & pilotage manuel</summary>
                <div class="content-fiche__details-body">
                    {{ form_row(form.title) }}
                    {{ form_row(form.client) }}
                    {{ form_row(form.scheduledDate) }}
                    {{ form_row(form.asanaMontageDueOn) }}
                    {{ form_row(form.format) }}
                    <div class="subtitles-field-row">
                        <span class="field-label" id="label-video-subtitles">Sous-titres</span>
                        <label class="toggle-switch" aria-labelledby="label-video-subtitles">
                            {{ form_widget(form.videoHasSubtitles) }}
                            <span class="toggle-switch-ui" aria-hidden="true"></span>
                        </label>
                    </div>
                    {{ form_errors(form.videoHasSubtitles) }}
                    {{ form_row(form.status) }}
                </div>
            </details>

            <div class="content-fiche__save-bar">
                {{ form_widget(form._token) }}
                <button type="submit" class="btn">Enregistrer les modifications</button>
            </div>

            {{ form_end(form, { render_rest: false }) }}

            <section id="retours-discussion" class="content-fiche__section">
                <div class="content-fiche__section-head">
                    <h2>Retours / discussion</h2>
                </div>
                {% if content.comments is empty %}
                    <p style="color: var(--muted); margin: 0;">Aucun retour pour le moment.</p>
                {% else %}
                    <div style="display: grid; gap: 0.6rem; margin-bottom: 1rem;">
                        {% for c in content.comments %}
                            <div style="border: 1px solid var(--card-border); border-radius: 10px; padding: 0.75rem; background: var(--bg);">
                                <div style="display:flex; justify-content: space-between; gap: 1rem; font-size: 0.85rem; color: var(--muted); margin-bottom: 0.35rem;">
                                    <strong style="color: var(--text);">{{ c.author ? c.author.name : '—' }}</strong>
                                    <time>{{ c.createdAt|date('d/m/Y H:i') }}</time>
                                </div>
                                <div style="white-space: pre-wrap;">{{ c.message }}</div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
                <form method="post" action="{{ path('app_content_comment', {id: content.id}) }}" style="display:grid; gap: 0.6rem;">
                    <input type="hidden" name="_token" value="{{ csrf_token('comment' ~ content.id) }}">
                    <label for="video-comment-message" class="field-label">Ajouter un retour</label>
                    <textarea id="video-comment-message" name="message" rows="4" placeholder="Message pour prod, CM ou monteur…" style="width: 100%;"></textarea>
                    <button type="submit" class="btn">Publier le commentaire</button>
                </form>
            </section>

            <section class="content-fiche__danger" aria-labelledby="video-delete-heading">
                <h2 id="video-delete-heading">Supprimer cette vidéo</h2>
                <p style="color: var(--muted); font-size: 0.88rem; margin: 0 0 1rem;">Action irréversible.</p>
                <form method="post" action="{{ path('app_content_delete', {id: content.id}) }}" onsubmit="return confirm('Supprimer définitivement cette vidéo ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ content.id) }}">
                    <input type="hidden" name="_return_to" value="{{ return_to_val }}">
                    <button type="submit" class="btn btn-danger">Supprimer</button>
                </form>
            </section>
        </div>
    </div>
</div>

<script>
(function () {
    document.querySelectorAll('.js-vf-link-open').forEach(function (btn) {
        var input = document.getElementById(btn.getAttribute('data-input-id'));
        if (!input) return;
        function sync() {
            var v = (input.value || '').trim();
            btn.href = v || '#';
            btn.hidden = !v;
        }
        input.addEventListener('input', sync);
        input.addEventListener('change', sync);
        sync();
    });
})();
</script>
{% endblock %}
