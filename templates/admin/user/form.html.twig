{% extends 'base.html.twig' %}

{% block title %}{{ user.id ? 'Modifier' : 'Nouveau' }} utilisateur{% endblock %}

{% block body %}
<h1>{{ user.id ? 'Modifier' : 'Nouveau' }} utilisateur</h1>
<p><a href="{{ path('app_admin_user_index') }}">← Retour</a></p>

<form method="post" style="max-width: 620px;">
    <label for="name">Nom</label>
    <input type="text" id="name" name="name" value="{{ user.name }}" required>

    <label for="email">Email</label>
    <input type="email" id="email" name="email" value="{{ user.email }}" required>

    <label for="password">{{ user.id ? 'Mot de passe (laisser vide pour ne pas changer)' : 'Mot de passe' }}</label>
    <input type="password" id="password" name="password" value="">

    {% set roles = user.roles %}
    <div style="margin: 1rem 0 0.5rem; padding: 0.85rem; border: 1px solid var(--card-border); border-radius: 12px; background: var(--card-bg);">
        <strong>Compte client (lecture seule)</strong>
        <div style="display:grid; gap: 0.35rem; margin-top: 0.5rem;">
            <label class="check-item" style="display:flex; align-items:center; gap: 0.5rem;">
                <input type="checkbox" id="isClientAccount" name="isClientAccount" value="1" {{ 'ROLE_CLIENT' in roles ? 'checked' : '' }}>
                <span>Activer ce compte comme <strong>client</strong> (accès uniquement à l’agenda)</span>
            </label>
        </div>

        <div id="clientAccessBlock" style="margin-top: 0.75rem; display: none;">
            <label for="client_ids"><strong>Clients accessibles</strong></label>
            <select id="client_ids" name="client_ids[]" multiple size="10" style="width: 100%; min-height: 220px;">
                {% set selectedIds = user.clientAccesses|map(c => c.id) %}
                {% for c in clients %}
                    <option value="{{ c.id }}" {{ c.id in selectedIds ? 'selected' : '' }}>{{ c.name }}</option>
                {% endfor %}
            </select>
            <div style="color: var(--muted); font-size: 0.85rem; margin-top: 0.35rem;">
                Astuce : maintiens Ctrl (Windows) pour sélectionner plusieurs clients.
            </div>
        </div>
    </div>

    <div style="margin: 1rem 0 0.5rem;">
        <strong>Rôles</strong>
        <div style="display:grid; gap: 0.35rem; margin-top: 0.5rem;">
            <label class="check-item" style="display:flex; align-items:center; gap: 0.5rem;">
                <input type="checkbox" name="isAdmin" value="1" {{ 'ROLE_ADMIN' in roles ? 'checked' : '' }}>
                <span>Admin (voit tout + peut valider PROD)</span>
            </label>
            <label class="check-item" style="display:flex; align-items:center; gap: 0.5rem;">
                <input type="checkbox" name="isCommunityManager" value="1" {{ 'ROLE_CM' in roles ? 'checked' : '' }}>
                <span>Community Manager</span>
            </label>
            <label class="check-item" style="display:flex; align-items:center; gap: 0.5rem;">
                <input type="checkbox" name="isEditor" value="1" {{ 'ROLE_EDITOR' in roles ? 'checked' : '' }}>
                <span>Monteur</span>
            </label>
        </div>
    </div>

    <div style="margin: 1rem 0 0.5rem;">
        <strong>Asana</strong>
        <div style="display:grid; gap: 0.35rem; margin-top: 0.5rem;">
            <label for="asanaUserGid">Asana — User GID (monteur)</label>
            <input type="text" id="asanaUserGid" name="asanaUserGid" value="{{ user.asanaUserGid }}" placeholder="ex: 1201234567890123">
            <div style="color: var(--muted); font-size: 0.85rem; max-width: 520px;">
                Si vide, les tâches seront assignées à l’utilisateur “fallback” (Nicolas) si configuré.
            </div>
        </div>
    </div>

    <button type="submit" class="btn">Enregistrer</button>
</form>

<script>
    (function initClientAccountForm() {
        var chk = document.getElementById('isClientAccount');
        var block = document.getElementById('clientAccessBlock');
        if (!chk || !block) return;

        function sync() {
            var isClient = !!chk.checked;
            block.style.display = isClient ? 'block' : 'none';
        }

        chk.addEventListener('change', sync);
        sync();
    })();
</script>
{% endblock %}

