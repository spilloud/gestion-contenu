{% extends 'base.html.twig' %}

{% block title %}Planning {{ year }} — {{ client.name }}{% endblock %}

{% block body %}
<style>
    .year-planning-toolbar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .year-planning-toolbar h1 {
        margin: 0;
        font-size: 1.35rem;
    }
    .year-planning-toolbar .subtitle {
        color: var(--muted);
        font-size: 0.9rem;
        margin-top: 0.2rem;
    }
    .year-planning-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
    }
    .year-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
    }
    .year-nav a {
        text-decoration: none;
        color: var(--text);
        border: 1px solid var(--card-border);
        border-radius: 999px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--input-bg);
        font-weight: 700;
    }
    .year-nav a:hover {
        background: var(--sidebar-active);
        color: #fff;
    }
    .year-label {
        font-weight: 700;
        min-width: 3.5rem;
        text-align: center;
    }
    .year-planning-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        font-size: 0.82rem;
        color: var(--muted);
        margin-bottom: 0.75rem;
    }
    .year-planning-legend span {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }
    .legend-content {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 2px;
        background: #64748b;
    }
    .legend-event-v {
        width: 0.45rem;
        height: 1.1rem;
        border-radius: 2px;
        background: #cbd5e1;
        border: 1px solid #94a3b8;
    }
    .year-planning-wrap {
        overflow-x: auto;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 12px;
        padding: 0.5rem;
    }
    .year-planning-table {
        width: 100%;
        min-width: 1200px;
        border-collapse: collapse;
        table-layout: fixed;
        font-size: 0.74rem;
        line-height: 1.25;
    }
    .year-planning-table thead th {
        background: var(--surface-inset);
        border: 1px solid var(--card-border);
        padding: 0.5rem 0.25rem;
        font-weight: 700;
        text-align: center;
        font-size: 0.82rem;
    }
    .year-week-cell {
        border: 1px solid var(--card-border);
        vertical-align: top;
        padding: 0;
        height: 5.5rem;
        min-height: 5.5rem;
        width: 8.33%;
        background: var(--card-bg);
        position: relative;
    }
    .year-week-cell--empty {
        background: rgba(148, 163, 184, 0.06);
    }
    body.theme-dark .year-week-cell--empty {
        background: rgba(15, 23, 42, 0.4);
    }
    .year-week-cell__inner {
        position: relative;
        height: 100%;
        min-height: 5.5rem;
        padding: 1.35rem 0.3rem 0.3rem;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        overflow: hidden;
    }
    .year-week-num {
        position: absolute;
        top: 0.2rem;
        right: 0.3rem;
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--muted);
        line-height: 1;
        z-index: 2;
    }
    .year-week-contents {
        flex: 1 1 auto;
        min-height: 0;
        overflow: hidden;
    }
    .year-week-contents ul {
        margin: 0;
        padding: 0;
        list-style: none;
    }
    .year-week-contents li {
        margin-bottom: 0.12rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .year-week-contents a {
        color: var(--text);
        text-decoration: none;
    }
    .year-week-contents a:hover {
        text-decoration: underline;
    }
    .year-week-events {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        align-items: flex-start;
        gap: 0.15rem;
        max-height: 2.2rem;
        overflow: hidden;
        flex-shrink: 0;
    }
    .year-event {
        display: block;
        text-decoration: none;
        border-radius: 3px;
        font-size: 0.65rem;
        font-weight: 600;
        line-height: 1.15;
        box-sizing: border-box;
        border: 1px solid rgba(0, 0, 0, 0.1);
    }
    .year-event:hover {
        filter: brightness(0.95);
    }
    .year-event--inline {
        padding: 0.1rem 0.25rem;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .year-event--vertical {
        writing-mode: vertical-rl;
        text-orientation: mixed;
        transform: rotate(180deg);
        padding: 0.2rem 0.12rem;
        max-height: 2rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .year-print-header {
        display: none;
    }

    @page {
        size: A4 landscape;
        margin: 8mm 10mm;
    }

    @media print {
        .year-print-header {
            display: block;
            margin-bottom: 4mm;
        }
        .year-print-header__box {
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            justify-content: space-between;
            gap: 4mm 8mm;
            border: 1px solid #6b7280;
            border-radius: 4px;
            padding: 3mm 5mm;
            background: #fff;
        }
        .year-print-header__title {
            font-size: 12pt;
            font-weight: 700;
            line-height: 1.3;
        }
        .year-print-header__title span {
            font-weight: 500;
            color: #374151;
        }
        .year-print-header__meta {
            display: flex;
            flex-wrap: wrap;
            gap: 5mm 10mm;
            font-size: 9pt;
            line-height: 1.35;
        }
        .year-print-header__meta dt {
            font-weight: 700;
            margin: 0;
        }
        .year-print-header__meta dd {
            margin: 0;
        }
        .year-print-header__meta div {
            display: flex;
            flex-direction: column;
            gap: 0.5mm;
        }
        .sidebar,
        .topbar,
        .year-planning-toolbar,
        .year-planning-actions .btn,
        .year-planning-actions .year-nav a,
        .no-print {
            display: none !important;
        }
        .layout { display: block; }
        .main { margin: 0; padding: 0; }
        .page-content { padding: 0; }
        body { background: #fff; color: #111; }
        .year-planning-wrap {
            border: 0;
            padding: 0;
            overflow: visible;
        }
        .year-planning-table {
            font-size: 6.5pt;
            min-width: 0;
        }
        .year-week-cell {
            height: 4.2rem;
            min-height: 4.2rem;
        }
        .year-week-cell__inner {
            min-height: 4.2rem;
            padding-top: 1.1rem;
        }
        .year-week-num {
            color: #374151;
        }
        .year-week-contents a,
        .year-event {
            color: inherit;
        }
        .year-planning-table thead th {
            background: #f3f4f6 !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
    }
</style>

<div class="year-planning-toolbar">
    <div>
        <h1>{{ client.name }}</h1>
        <div class="subtitle">Planning annuel {{ year }} — semaines par mois</div>
    </div>
    <div class="year-planning-actions">
        <div class="year-nav no-print">
            <a href="{{ path('app_client_year_planning', {id: client.id, year: prevYear}) }}" title="Année précédente">‹</a>
            <span class="year-label">{{ year }}</span>
            <a href="{{ path('app_client_year_planning', {id: client.id, year: nextYear}) }}" title="Année suivante">›</a>
        </div>
        <a href="{{ path('app_client_show', {id: client.id, cyear: year}) }}" class="btn btn-sm no-print">Fiche client</a>
        <button type="button" class="btn btn-sm no-print" onclick="window.print()">Imprimer / PDF</button>
    </div>
</div>

<div class="year-planning-legend no-print">
    <span><span class="legend-content" aria-hidden="true"></span> Contenu (titre)</span>
    <span><span class="legend-event-v" aria-hidden="true"></span> Événement multi-jours (vertical)</span>
</div>

<header class="year-print-header" aria-label="En-tête document imprimable">
    <div class="year-print-header__box">
        <div class="year-print-header__title">
            {{ client.name }}
            <span>— Planning annuel {{ year }}</span>
        </div>
        <dl class="year-print-header__meta">
            <div>
                <dt>Date du document</dt>
                <dd>{{ 'now'|date('d/m/Y') }}</dd>
            </div>
            <div>
                <dt>Community manager</dt>
                <dd>{{ client.communityManager ? client.communityManager.name : '—' }}</dd>
            </div>
        </dl>
    </div>
</header>

<div class="year-planning-wrap">
    <table class="year-planning-table">
        <thead>
            <tr>
                {% for monthNum, monthLabel in grid.months %}
                    <th>{{ monthLabel }}</th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% for row in 0..(grid.rowCount - 1) %}
                <tr>
                    {% for monthNum, monthLabel in grid.months %}
                        {% set cell = grid.grid[monthNum][row] ?? null %}
                        <td class="year-week-cell{{ cell ? '' : ' year-week-cell--empty' }}">
                            {% if cell %}
                                <div class="year-week-cell__inner">
                                    <span class="year-week-num" title="Semaine {{ cell.isoWeek }}">S{{ '%02d'|format(cell.isoWeek) }}</span>
                                    <div class="year-week-events">
                                        {% for event in cell.events %}
                                            <a
                                                href="{{ path('app_calendar_event_edit', {id: event.id, return_to: app.request.requestUri}) }}"
                                                class="year-event {{ event.vertical ? 'year-event--vertical' : 'year-event--inline' }}"
                                                style="background: {{ event.color }};"
                                                title="{{ event.title }} ({{ event.daySpan }} j)"
                                            >{{ event.title }}</a>
                                        {% endfor %}
                                    </div>
                                    <div class="year-week-contents">
                                        {% if cell.contents is not empty %}
                                            <ul>
                                                {% for content in cell.contents %}
                                                    <li>
                                                        <a href="{{ path('app_content_edit', {id: content.id}) }}" title="{{ content.title }}">{{ content.title }}</a>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
