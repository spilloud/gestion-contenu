<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nouveau mot de passe | Gestion des contenus</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap');
        body {
            font-family: "Public Sans", system-ui, sans-serif;
            margin: 0;
            padding: 2rem;
            background: linear-gradient(135deg, #140b2e, #1c1040 55%, #3b1c78);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .box {
            background: rgba(255,255,255,0.98);
            padding: 2rem;
            border-radius: 14px;
            box-shadow: 0 24px 40px rgba(2, 6, 23, 0.35);
            max-width: 430px;
            width: 100%;
        }
        .logo { margin-bottom: 1rem; }
        .logo img { width: 170px; object-fit: contain; }
        h1 { margin-top: 0; font-size: 1.25rem; }
        label { display: block; margin-bottom: 0.35rem; font-weight: 600; color: #334155; }
        input[type="password"] {
            width: 100%;
            padding: 0.66rem;
            margin-bottom: 1rem;
            border: 1px solid #dbe1ea;
            border-radius: 8px;
            font-size: 0.95rem;
        }
        button {
            width: 100%;
            padding: 0.78rem;
            background: #5b21b6;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 0.96rem;
            font-weight: 600;
            cursor: pointer;
        }
        button:hover { background: #4c1d95; }
        p.hint { color: #64748b; font-size: 0.88rem; margin-top: 0; }
    </style>
</head>
<body>
    <div class="box">
        <div class="logo">
            <img src="{{ asset('logo-login-noir-violet.svg') }}" alt="Logo Osmose Marketing">
        </div>
        <h1>Choisir un nouveau mot de passe</h1>
        <p class="hint">Au moins 8 caractères.</p>
        <form method="post" action="{{ path('app_reset_password', { token: token }) }}">
            <label for="password">Nouveau mot de passe</label>
            <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8" autofocus>
            <label for="password_confirm">Confirmer</label>
            <input type="password" id="password_confirm" name="password_confirm" required autocomplete="new-password" minlength="8">
            <input type="hidden" name="_token" value="{{ csrf_token('reset_password') }}">
            <button type="submit">Enregistrer</button>
        </form>
    </div>
</body>
</html>
