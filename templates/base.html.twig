<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="{{ asset('favicon-32x32.webp') }}" sizes="32x32" type="image/webp">
    <link rel="icon" href="{{ asset('favicon-192x192.webp') }}" sizes="192x192" type="image/webp">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.webp') }}">
    <title>{% block title %}Gestion des contenus{% endblock %} | Osmose</title>
    {% block stylesheets %}
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap');
            :root {
                --bg: #f1f5f9;
                --text: #0f172a;
                --topbar-bg: #ffffff;
                --topbar-border: #e2e8f0;
                --card-bg: #ffffff;
                --card-border: #e2e8f0;
                --muted: #475569;
                --label: #334155;
                --input-bg: #ffffff;
                --input-border: #dbe1ea;
                --link: #5b21b6;
                --link-hover: #4c1d95;
                --shadow-dropdown: 0 12px 30px rgba(2, 6, 23, 0.12);
                --sidebar-bg: #140b2e;
                --sidebar-text: #cbd5e1;
                --sidebar-hover: #27124f;
                --sidebar-active: #4c1d95;
                --flash-success-bg: #ecfdf3;
                --flash-success-text: #166534;
                --flash-success-border: #bbf7d0;
                --flash-error-bg: #fef2f2;
                --flash-error-text: #991b1b;
                --flash-error-border: #fecaca;
                --surface-inset: #eef2f7;
                --surface-inset-2: #e2e8f0;
                --table-head-bg: #1c1040;
                --table-head-text: #f8fafc;
                --table-border: #e2e8f0;
            }
            body.theme-dark {
                --bg: #090f18;
                --text: #f1f5f9;
                --topbar-bg: #0f172a;
                --topbar-border: #1e293b;
                --card-bg: #131c2e;
                --card-border: #273449;
                --muted: #b8c9dc;
                --label: #cbd5e1;
                --input-bg: #0c1424;
                --input-border: #334155;
                --link: #c4b5fd;
                --link-hover: #ddd6fe;
                --shadow-dropdown: 0 16px 48px rgba(0, 0, 0, 0.55);
                --sidebar-bg: #050508;
                --sidebar-text: #cbd5e1;
                --sidebar-hover: #312065;
                --sidebar-active: #6d28d9;
                --flash-success-bg: #052e16;
                --flash-success-text: #bbf7d0;
                --flash-success-border: #166534;
                --flash-error-bg: #450a0a;
                --flash-error-text: #fecaca;
                --flash-error-border: #991b1b;
                --surface-inset: #1a2438;
                --surface-inset-2: #151d30;
                --table-head-bg: #2d1b69;
                --table-head-text: #f1f5f9;
                --table-border: #334155;
            }
            * { box-sizing: border-box; }
            body {
                font-family: "Public Sans", system-ui, -apple-system, sans-serif;
                margin: 0;
                background: var(--bg);
                color: var(--text);
            }
            .layout { display: flex; min-height: 100vh; }
            .sidebar {
                width: 260px;
                background: var(--sidebar-bg);
                color: var(--sidebar-text);
                padding: 1rem 0.75rem;
                box-shadow: 2px 0 18px rgba(20, 11, 46, 0.28);
                display: flex;
                flex-direction: column;
                position: sticky;
                top: 0;
                align-self: flex-start;
                height: 100vh;
                max-height: 100vh;
                overflow-y: auto;
            }
            .brand {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.5rem 0.75rem 1rem;
                margin-bottom: 0.6rem;
                border-bottom: 1px solid rgba(148, 163, 184, 0.2);
            }
            .brand img { width: 150px; height: auto; object-fit: contain; }
            .brand strong { font-size: 1rem; color: #fff; }
            .sidebar-nav {
                display: flex;
                flex-direction: column;
                gap: 0.15rem;
                flex: 1;
                min-height: 0;
            }
            .sidebar-nav__main {
                flex: 1 1 auto;
                display: flex;
                flex-direction: column;
                gap: 0.15rem;
                min-height: 0;
                overflow-y: auto;
            }
            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 0.65rem;
                padding: 0.62rem 0.75rem;
                color: var(--sidebar-text);
                text-decoration: none;
                border-radius: 0.55rem;
                font-size: 0.9rem;
                line-height: 1.25;
            }
            .sidebar-link:hover {
                background: var(--sidebar-hover);
                color: #fff;
            }
            .sidebar-link.active {
                background: var(--sidebar-active);
                color: #fff;
            }
            .sidebar-link__icon {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 1.15rem;
                height: 1.15rem;
                flex-shrink: 0;
                opacity: 0.92;
            }
            .sidebar-link__icon svg {
                display: block;
                width: 100%;
                height: 100%;
            }
            .sidebar-link.active .sidebar-link__icon,
            .sidebar-link:hover .sidebar-link__icon {
                opacity: 1;
            }
            .sidebar-link__label {
                flex: 1;
                min-width: 0;
            }
            .sidebar-section {
                margin-bottom: 0.35rem;
            }
            .sidebar-section--dashboard {
                padding-bottom: 0.65rem;
                margin-bottom: 0.5rem;
                border-bottom: 1px solid rgba(148, 163, 184, 0.22);
            }
            .sidebar-section--admin {
                flex-shrink: 0;
                margin-top: auto;
                padding: 0.85rem 0.55rem 0.55rem;
                background: rgba(0, 0, 0, 0.22);
                border: 1px solid rgba(148, 163, 184, 0.18);
                border-radius: 0.65rem;
            }
            body.theme-dark .sidebar-section--admin {
                background: rgba(0, 0, 0, 0.45);
                border-color: rgba(148, 163, 184, 0.12);
            }
            .sidebar h3 {
                padding: 0 0.55rem;
                font-size: 0.7rem;
                font-weight: 600;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                color: #94a3b8;
                margin: 0 0 0.55rem;
            }
            .main { flex: 1; min-width: 0; }
            .topbar {
                background: var(--topbar-bg);
                border-bottom: 1px solid var(--topbar-border);
                padding: 1rem 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 10;
            }
            .topbar .title { font-weight: 600; font-size: 1rem; color: var(--text); }
            .topbar-actions { display: flex; align-items: center; gap: 0.6rem; }
            .topbar-btn {
                border: 1px solid var(--card-border);
                background: var(--card-bg);
                color: var(--text);
                border-radius: 8px;
                padding: 0.4rem 0.55rem;
                cursor: pointer;
                font-size: 0.86rem;
            }
            .user-dropdown { position: relative; }
            .user-dropdown-menu {
                display: none;
                position: absolute;
                right: 0;
                top: calc(100% + 8px);
                min-width: 190px;
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 10px;
                padding: 0.4rem;
                box-shadow: var(--shadow-dropdown);
            }
            .user-dropdown.open .user-dropdown-menu { display: block; }
            .user-dropdown-menu a {
                display: block;
                text-decoration: none;
                color: var(--text);
                padding: 0.5rem 0.6rem;
                border-radius: 8px;
                font-size: 0.86rem;
            }
            .user-dropdown-menu a:hover { background: var(--sidebar-hover); color: #fff; }
            .page-content { padding: 1.5rem; }
            .flash-success, .flash-error {
                padding: 0.8rem 0.9rem;
                border-radius: 0.6rem;
                margin-bottom: 1rem;
                border: 1px solid transparent;
            }
            .flash-success {
                background: var(--flash-success-bg);
                color: var(--flash-success-text);
                border-color: var(--flash-success-border);
            }
            .flash-error {
                background: var(--flash-error-bg);
                color: var(--flash-error-text);
                border-color: var(--flash-error-border);
            }
            .btn {
                display: inline-block;
                padding: 0.5rem 0.9rem;
                background: #5b21b6;
                color: #fff;
                border: none;
                border-radius: 0.5rem;
                cursor: pointer;
                text-decoration: none;
                font-size: 0.88rem;
                font-weight: 500;
            }
            .btn:hover { background: #4c1d95; }
            .btn-danger { background: #dc2626; }
            .btn-danger:hover { background: #b91c1c; }
            .btn-sm { padding: 0.34rem 0.62rem; font-size: 0.78rem; }
            form label { display: block; margin-bottom: 0.3rem; font-weight: 500; color: var(--label); }
            .page-content a:not(.btn):not(.btn-danger):not(.badge-mini) {
                color: var(--link);
            }
            .page-content a:not(.btn):not(.btn-danger):not(.badge-mini):hover {
                color: var(--link-hover);
                text-decoration: underline;
            }
            a.badge-mini {
                text-decoration: none;
            }
            a.badge-mini:hover {
                filter: brightness(1.06);
            }
            .badge-mini {
                display: inline-block;
                margin-top: 0.25rem;
                margin-right: 0.25rem;
                padding: 0.15rem 0.45rem;
                border-radius: 999px;
                font-size: 0.74rem;
                font-weight: 600;
                border: 1px solid transparent;
                background: rgba(91, 33, 182, 0.12);
                color: #4338ca;
            }
            body.theme-dark .badge-mini {
                background: rgba(139, 92, 246, 0.22);
                color: #f5f3ff;
                border-color: rgba(167, 139, 250, 0.35);
            }
            form input[type="text"], form input[type="email"], form input[type="password"], form input[type="number"], form select, form textarea {
                width: 100%;
                max-width: 400px;
                padding: 0.55rem 0.6rem;
                margin-bottom: 1rem;
                border: 1px solid var(--input-border);
                border-radius: 0.5rem;
                background: var(--input-bg);
                color: var(--text);
            }
            .status-badge { display: inline-block; padding: 0.25rem 0.5rem; border-radius: 999px; font-size: 0.77rem; font-weight: 600; }
            .status-gray { background: #95a5a6; color: white; }
            .status-red { background: #e74c3c; color: white; }
            .status-orange { background: #e67e22; color: white; }
            .status-yellow { background: #f1c40f; color: #333; }
            .status-lightgreen { background: #2ecc71; color: white; }
            .status-green { background: #27ae60; color: white; }
            .status-taupe { background: #8b7d70; color: #fff; }
            .status-canard { background: #0f6b6f; color: #fff; }
            .status-violet { background: #6d28d9; color: #fff; }
            .status-bleu-nuit { background: #1e3a8a; color: #fff; }
            .status-ardoise { background: #475569; color: #fff; }
            .status-sauge { background: #7c9a92; color: #fff; }
            .status-menthe { background: #34d399; color: #0f172a; }
            .status-moutarde { background: #cfa500; color: #1f2937; }
            .status-corail { background: #fb7185; color: #fff; }
            .status-framboise { background: #be185d; color: #fff; }
            .status-rose-poudre { background: #f9a8d4; color: #5b2146; }
            .status-fuchsia { background: #d946ef; color: #fff; }
            h1 { margin-top: 0; margin-bottom: 1rem; font-size: 1.45rem; }
            table { background: var(--card-bg); border-radius: 0.75rem; }
            .page-content table { color: var(--text); }
            .page-content .data-sheet {
                width: 100%;
                background: var(--card-bg);
                color: var(--text);
                border-radius: 8px;
                border-collapse: collapse;
                overflow: hidden;
                border: 1px solid var(--card-border);
            }
            .page-content .data-sheet thead tr {
                background: var(--table-head-bg);
                color: var(--table-head-text);
            }
            .page-content .data-sheet thead th,
            .page-content .data-sheet thead th a {
                color: inherit;
            }
            .page-content .data-sheet tbody tr {
                border-bottom: 1px solid var(--table-border);
            }
            .page-content .data-sheet tbody td {
                color: var(--text);
            }
            .page-content .data-sheet tbody tr.data-sheet__group td {
                background: var(--surface-inset);
                color: var(--text);
                font-weight: 700;
                border-color: var(--table-border);
            }
            .page-content .data-sheet tbody tr.data-sheet__group small {
                color: var(--muted);
            }
            /* Interrupteur (sous-titres, etc.) */
            .toggle-switch {
                position: relative;
                display: inline-flex;
                align-items: center;
                cursor: pointer;
                user-select: none;
                vertical-align: middle;
            }
            .toggle-switch input {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }
            .toggle-switch-ui {
                width: 48px;
                height: 26px;
                background: #cbd5e1;
                border-radius: 999px;
                position: relative;
                transition: background 0.2s ease;
                flex-shrink: 0;
            }
            body.theme-dark .toggle-switch-ui { background: #475569; }
            .toggle-switch-ui::after {
                content: '';
                position: absolute;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #fff;
                top: 3px;
                left: 4px;
                box-shadow: 0 1px 3px rgba(15, 23, 42, 0.25);
                transition: transform 0.2s ease;
            }
            .toggle-switch input:checked + .toggle-switch-ui {
                background: #5b21b6;
            }
            .toggle-switch input:checked + .toggle-switch-ui::after {
                transform: translateX(20px);
            }
            .toggle-switch:focus-within .toggle-switch-ui {
                outline: 2px solid #a78bfa;
                outline-offset: 2px;
            }
            .subtitles-field-row {
                display: flex;
                align-items: center;
                gap: 0.85rem;
                margin-bottom: 1rem;
                flex-wrap: wrap;
            }
            .subtitles-field-row label.field-label {
                font-weight: 500;
                color: var(--label);
                margin: 0;
            }
            body.theme-dark .subtitles-field-row label.field-label { color: #e2e8f0; }

            .theme-switch-wrap {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
            }
            .theme-switch__mascot {
                display: flex;
                align-items: center;
                justify-content: center;
                color: #64748b;
                flex-shrink: 0;
            }
            body.theme-dark .theme-switch__mascot {
                color: #c4b5fd;
            }
            .theme-switch__mascot svg {
                width: 22px;
                height: 22px;
                display: block;
                opacity: 0.72;
            }
            body.theme-dark .theme-switch__mascot svg {
                opacity: 0.95;
            }
            /* Thème : interrupteur (soleil / Dark Vador) */
            .theme-switch {
                position: relative;
                width: 52px;
                height: 30px;
                border-radius: 999px;
                border: 1px solid var(--card-border);
                background: linear-gradient(180deg, var(--input-bg) 0%, var(--card-bg) 100%);
                cursor: pointer;
                padding: 0;
                flex-shrink: 0;
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
            }
            .theme-switch:hover {
                border-color: var(--sidebar-active);
                box-shadow: 0 0 0 3px rgba(91, 33, 182, 0.18);
            }
            body.theme-dark .theme-switch:hover {
                box-shadow: 0 0 0 3px rgba(167, 139, 250, 0.2);
            }
            .theme-switch:focus-visible {
                outline: 2px solid #a78bfa;
                outline-offset: 3px;
            }
            .theme-switch__thumb {
                position: absolute;
                top: 3px;
                left: 3px;
                width: 22px;
                height: 22px;
                border-radius: 50%;
                background: #fff;
                box-shadow: 0 1px 4px rgba(15, 23, 42, 0.22);
                display: grid;
                place-items: center;
                transition: transform 0.22s ease, background 0.2s ease;
                color: #d97706;
            }
            body.theme-dark .theme-switch__thumb {
                transform: translateX(22px);
                background: #1e293b;
                color: #e2e8f0;
                box-shadow: 0 1px 6px rgba(0, 0, 0, 0.45);
            }
            .theme-switch__icon {
                grid-area: 1 / 1;
                display: flex;
                align-items: center;
                justify-content: center;
                width: 14px;
                height: 14px;
                opacity: 0;
                transition: opacity 0.15s ease;
                pointer-events: none;
            }
            .theme-switch__icon--sun {
                opacity: 1;
                color: #ea580c;
            }
            body.theme-dark .theme-switch__icon--sun { opacity: 0; }
            body.theme-dark .theme-switch__icon--vader { opacity: 1; }
            .theme-switch__icon svg { display: block; width: 14px; height: 14px; }
            .theme-switch__sr {
                position: absolute;
                width: 1px;
                height: 1px;
                padding: 0;
                margin: -1px;
                overflow: hidden;
                clip: rect(0, 0, 0, 0);
                white-space: nowrap;
                border: 0;
            }
        </style>
    {% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body data-turbo="false">
    <div class="layout">
        <nav class="sidebar">
            <div class="brand">
                <img src="{{ asset('logo-site-blanc.svg') }}" alt="Logo Osmose Marketing">
            </div>
            {% set currentRoute = app.request.attributes.get('_route') %}

            <div class="sidebar-nav">
                <div class="sidebar-nav__main">
                <div class="sidebar-section sidebar-section--dashboard">
                    <a href="{{ path('app_dashboard') }}" class="sidebar-link {{ currentRoute in ['app_dashboard', 'app_home'] ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1z"/></svg>
                        </span>
                        <span class="sidebar-link__label">Dashboard</span>
                    </a>
                </div>

                <div class="sidebar-section">
                    <h3>Menu</h3>
                    <a href="{{ path('app_calendar') }}" class="sidebar-link {{ currentRoute == 'app_calendar' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                        </span>
                        <span class="sidebar-link__label">Calendrier des contenus</span>
                    </a>
                    <a href="{{ path('app_clients_table') }}" class="sidebar-link {{ currentRoute == 'app_clients_table' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="3"/><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </span>
                        <span class="sidebar-link__label">Clients sous gestion</span>
                    </a>
                    <a href="{{ path('app_derush_index') }}" class="sidebar-link {{ currentRoute == 'app_derush_index' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                        </span>
                        <span class="sidebar-link__label">Dérush vidéo</span>
                    </a>
                    <a href="{{ path('app_calendar_events_index') }}" class="sidebar-link {{ currentRoute starts with 'app_calendar_event' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        </span>
                        <span class="sidebar-link__label">Événements</span>
                    </a>
                    <a href="{{ path('app_reports_index') }}" class="sidebar-link {{ currentRoute starts with 'app_reports_' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V10M10 20V4M16 20v-6M22 20H2"/></svg>
                        </span>
                        <span class="sidebar-link__label">Rapports</span>
                    </a>
                    <a href="{{ path('app_videos_index') }}" class="sidebar-link {{ currentRoute starts with 'app_videos_' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="m10 9 6 4-6 4V9z"/></svg>
                        </span>
                        <span class="sidebar-link__label">Vidéos</span>
                    </a>
                </div>
                </div>

                <div class="sidebar-section sidebar-section--admin">
                    <h3>Administration</h3>
                    <a href="{{ path('app_admin_client_index') }}" class="sidebar-link {{ currentRoute starts with 'app_admin_client' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect x="2" y="8" width="20" height="14" rx="2"/></svg>
                        </span>
                        <span class="sidebar-link__label">Clients</span>
                    </a>
                    <a href="{{ path('app_admin_cm_index') }}" class="sidebar-link {{ currentRoute starts with 'app_admin_cm' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11v2a4 4 0 0 1-4 4h-1"/></svg>
                        </span>
                        <span class="sidebar-link__label">Community Managers</span>
                    </a>
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                        <a href="{{ path('app_admin_integration_api') }}" class="sidebar-link {{ currentRoute in ['app_admin_integration_api', 'app_admin_integration_luc'] ? 'active' : '' }}">
                            <span class="sidebar-link__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                            </span>
                            <span class="sidebar-link__label">Intégration API</span>
                        </a>
                    {% endif %}
                    <a href="{{ path('app_admin_status_format_index') }}" class="sidebar-link {{ currentRoute starts with 'app_admin_status_' or currentRoute starts with 'app_admin_format_' or currentRoute == 'app_admin_status_format_index' ? 'active' : '' }}">
                        <span class="sidebar-link__icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7h16M4 12h10M4 17h16"/></svg>
                        </span>
                        <span class="sidebar-link__label">Statuts et formats</span>
                    </a>
                    {% if 'ROLE_ADMIN' in app.user.roles %}
                        <a href="{{ path('app_admin_user_index') }}" class="sidebar-link {{ currentRoute starts with 'app_admin_user' ? 'active' : '' }}">
                            <span class="sidebar-link__icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 4v5c0 4.4-3.1 8.5-7 9-3.9-.5-7-4.6-7-9V7l7-4z"/><circle cx="12" cy="11" r="2"/></svg>
                            </span>
                            <span class="sidebar-link__label">Utilisateurs</span>
                        </a>
                    {% endif %}
                </div>
            </div>
        </nav>
        <main class="main">
            <header class="topbar">
                <div class="title">Dashboard Contenu</div>
                <div class="topbar-actions">
                    <span class="theme-switch-wrap">
                    <button type="button" id="themeToggle" class="theme-switch" role="switch" aria-checked="false" title="Thème clair">
                        <span class="theme-switch__thumb">
                            <span class="theme-switch__icon theme-switch__icon--sun" aria-hidden="true">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                                    <circle cx="12" cy="12" r="4" fill="currentColor"/>
                                    <path fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" d="M12 3v2M12 19v2M5 5l1.5 1.5M17.5 17.5L19 19M3 12h2m14 0h2M5 19l1.5-1.5M17.5 6.5L19 5"/>
                                </svg>
                            </span>
                            <span class="theme-switch__icon theme-switch__icon--vader" aria-hidden="true">
                                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                                    <path fill="currentColor" d="M12 2.5L7.2 8.2c-.3.4-.5.9-.5 1.4V11H5l1.3 11h11.4L19 11h-1.7V9.6c0-.5-.2-1-.5-1.4L12 2.5zm0 2.2l3.6 4.8H8.4L12 4.7zM8.5 13h7l-.6 3h-5.8l-.6-3z"/>
                                </svg>
                            </span>
                        </span>
                        <span class="theme-switch__sr">Basculer entre thème clair et thème sombre</span>
                    </button>
                    <span class="theme-switch__mascot" aria-hidden="true">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" focusable="false">
                            <path fill="currentColor" d="M12 2.5L7.2 8.2c-.3.4-.5.9-.5 1.4V11H5l1.3 11h11.4L19 11h-1.7V9.6c0-.5-.2-1-.5-1.4L12 2.5zm0 2.2l3.6 4.8H8.4L12 4.7zM8.5 13h7l-.6 3h-5.8l-.6-3z"/>
                        </svg>
                    </span>
                    </span>
                    {% if app.user %}
                        <div class="user-dropdown" id="userDropdown">
                            <button type="button" class="topbar-btn">{{ app.user.userIdentifier }}</button>
                            <div class="user-dropdown-menu">
                                <a href="{{ path('app_profile_redirect') }}">Modifier mon profil</a>
                                <a href="{{ path('app_logout') }}">Deconnexion</a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </header>
            <div class="page-content">
                {% for message in app.flashes('success') %}
                    <div class="flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-error">{{ message }}</div>
                {% endfor %}
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>
    <script>
        (function () {
            var body = document.body;
            var savedTheme = localStorage.getItem('contenu-theme');
            if (savedTheme === 'dark') {
                body.classList.add('theme-dark');
            }

            var themeBtn = document.getElementById('themeToggle');
            if (themeBtn) {
                var syncThemeSwitch = function () {
                    var dark = body.classList.contains('theme-dark');
                    themeBtn.setAttribute('aria-checked', dark ? 'true' : 'false');
                    themeBtn.title = dark ? 'Revenir au thème clair' : 'Activer le thème sombre';
                };
                syncThemeSwitch();
                themeBtn.addEventListener('click', function () {
                    body.classList.toggle('theme-dark');
                    localStorage.setItem('contenu-theme', body.classList.contains('theme-dark') ? 'dark' : 'light');
                    syncThemeSwitch();
                });
            }

            var userDropdown = document.getElementById('userDropdown');
            if (userDropdown) {
                var button = userDropdown.querySelector('button');
                button.addEventListener('click', function (event) {
                    event.stopPropagation();
                    userDropdown.classList.toggle('open');
                });
                document.addEventListener('click', function () {
                    userDropdown.classList.remove('open');
                });
            }
        })();
    </script>
</body>
</html>
