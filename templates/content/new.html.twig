{% extends 'base.html.twig' %}

{% block title %}Nouveau contenu{% endblock %}

{% block body %}
<h1>Nouveau contenu</h1>
<p><a href="{{ returnTo|default(path('app_calendar')) }}">← Retour</a></p>

{{ form_start(form) }}
<input type="hidden" name="_return_to" value="{{ returnTo|default(path('app_calendar')) }}">
{{ form_widget(form) }}
<button type="submit" class="btn">Créer</button>
{{ form_end(form) }}
{% endblock %}
