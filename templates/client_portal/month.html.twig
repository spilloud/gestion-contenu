{% extends 'base.html.twig' %}

{% block title %}Agenda — {{ client.name }}{% endblock %}

{% block body %}
<style>
    .portal-toolbar {
        display:flex;
        align-items:center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .portal-nav {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
    }
    .portal-nav a {
        text-decoration: none;
        color: var(--text);
        border: 1px solid var(--card-border);
        border-radius: 999px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--input-bg);
        font-weight: 700;
    }
    .portal-nav a:hover {
        background: var(--sidebar-active);
        color: #fff;
    }
    .portal-label {
        font-weight: 800;
        min-width: 160px;
        text-align: center;
    }
    .portal-calendar table { width: 100%; border-collapse: collapse; }
    .portal-calendar th, .portal-calendar td {
        border: 1px solid var(--card-border);
        vertical-align: top;
        padding: 0.35rem;
        background: var(--card-bg);
        height: 110px;
    }
    .portal-calendar .event-bars-row td {
        padding: 0.35rem 0.35rem 0.1rem;
        height: auto;
        background: var(--card-bg);
    }
    .event-bars {
        display: grid;
        grid-template-columns: repeat(7, minmax(0, 1fr));
        gap: 0.25rem;
        align-items: stretch;
    }
    .event-bar {
        border-radius: 10px;
        border: 1px dashed rgba(148, 163, 184, 0.75);
        background: rgba(99, 102, 241, 0.08);
        padding: 0.25rem 0.4rem;
        min-height: 28px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        overflow: hidden;
    }
    body.theme-dark .event-bar {
        background: rgba(99, 102, 241, 0.12);
        border-color: rgba(148, 163, 184, 0.4);
    }
    .event-bar__dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        flex-shrink: 0;
        border: 1px solid rgba(0, 0, 0, 0.12);
    }
    .event-bar__title {
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 800;
        font-size: 0.82rem;
        color: var(--text);
    }
    .portal-calendar th { background: var(--surface-inset); font-weight: 800; }
    .day-head { display:flex; justify-content: space-between; color: var(--muted); font-size: 0.85rem; }
    .day-event {
        margin-top: 0.35rem;
        padding: 0.35rem 0.45rem;
        border-radius: 10px;
        border: 1px solid var(--card-border);
        background: var(--surface-inset);
    }
    .day-event__kind {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.15rem;
    }
    .day-event__kind svg { width: 14px; height: 14px; flex-shrink: 0; }
    .day-event strong { display:block; margin-bottom: 0.15rem; }
    .day-event .meta { color: var(--muted); font-size: 0.85rem; }
</style>

<div class="portal-toolbar">
    <div>
        <h1 style="margin:0;">{{ client.name }}</h1>
        <div style="color: var(--muted);">Agenda — lecture seule</div>
    </div>
    <div style="display:flex; flex-wrap:wrap; gap: 0.5rem; align-items:center;">
        <div class="portal-nav">
            <a href="{{ path('app_client_agenda_month', {id: client.id, year: prevMonth|date('Y'), month: prevMonth|date('n')}) }}" title="Mois précédent">‹</a>
            <span class="portal-label">{{ calendarMonthStart|date('F Y')|capitalize }}</span>
            <a href="{{ path('app_client_agenda_month', {id: client.id, year: nextMonth|date('Y'), month: nextMonth|date('n')}) }}" title="Mois suivant">›</a>
        </div>
        <a class="btn btn-sm" style="background:#64748b;" href="{{ path('app_client_agenda_year', {id: client.id, year: calendarYear}) }}">Vue annuelle {{ calendarYear }}</a>
        <a class="btn btn-sm" style="background:#64748b;" href="{{ path('app_client_agenda_home') }}">Changer de client</a>
    </div>
</div>

{% set gridStart = calendarMonthStart|date_modify('monday this week') %}
<div class="portal-calendar">
    <table>
        <thead>
            <tr>
                <th>Lundi</th>
                <th>Mardi</th>
                <th>Mercredi</th>
                <th>Jeudi</th>
                <th>Vendredi</th>
                <th>Samedi</th>
                <th>Dimanche</th>
            </tr>
        </thead>
        <tbody>
            {% for week in 0..5 %}
                {% set weekStart = gridStart|date_modify('+' ~ (week * 7) ~ ' days') %}
                {% set weekEnd = weekStart|date_modify('+6 days') %}
                {% set weekEvents = calendarEvents|filter(e => e.endDate >= weekStart and e.startDate <= weekEnd) %}
                <tr class="event-bars-row">
                    <td colspan="7">
                        <div class="event-bars" aria-label="Événements de la semaine">
                            {% for event in weekEvents %}
                                {% set overlapStart = event.startDate > weekStart ? event.startDate : weekStart %}
                                {% set overlapEnd = event.endDate < weekEnd ? event.endDate : weekEnd %}
                                {% set startCol = ((overlapStart|date('U') - weekStart|date('U')) / 86400)|round(0, 'floor') + 1 %}
                                {% set endCol = ((overlapEnd|date('U') - weekStart|date('U')) / 86400)|round(0, 'floor') + 1 %}
                                <div class="event-bar"
                                     style="grid-column: {{ startCol }} / {{ endCol + 1 }}; border-left: 4px solid {{ event.color ?: '#94a3b8' }};"
                                     title="{{ event.title }} ({{ event.startDate|date('d/m') }} → {{ event.endDate|date('d/m') }})">
                                    <span class="event-bar__dot" style="background: {{ event.color ?: '#94a3b8' }};" aria-hidden="true"></span>
                                    <span class="event-bar__title">Événement — {{ event.title }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </td>
                </tr>
                <tr>
                    {% for weekday in 0..6 %}
                        {% set offset = week * 7 + weekday %}
                        {% set dayObj = gridStart|date_modify('+' ~ offset ~ ' days') %}
                        {% set dayDate = dayObj|date('Y-m-d') %}
                        {% set inCurrentMonth = dayObj|date('m') == calendarMonthStart|date('m') %}
                        {% set dayContents = calendarContents|filter(c => c.scheduledDate and c.scheduledDate|date('Y-m-d') == dayDate) %}
                        <td style="{{ not inCurrentMonth ? 'opacity:0.55;' : '' }}">
                            <div class="day-head">
                                <strong style="color: var(--text);">{{ dayObj|date('d') }}</strong>
                                <span>{{ dayObj|date('d/m') }}</span>
                            </div>

                            {% for content in dayContents %}
                                <div class="day-event">
                                    <div class="day-event__kind">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                            <path d="M14 2v6h6"></path>
                                        </svg>
                                        Contenu
                                    </div>
                                    <strong>{{ content.title }}</strong>
                                    <div class="meta">
                                        {{ content.format ? content.format.name : '—' }}
                                        {% if content.status %} · {{ content.status.name }}{% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

