{% extends 'base.html.twig' %}

{% block title %}Modifier {{ content.title }}{% endblock %}

{% block body %}
<h1>Modifier {{ content.title }}</h1>
<p><a href="{{ returnTo|default(path('app_calendar')) }}">← Retour</a></p>

{{ form_start(form) }}
<input type="hidden" name="_return_to" value="{{ returnTo|default(path('app_calendar')) }}">
{{ form_widget(form) }}
<button type="submit" class="btn">Enregistrer</button>
{{ form_end(form) }}

<section style="margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--card-border, #e2e8f0); max-width: 520px;">
    <h2 style="font-size: 1rem; margin: 0 0 0.5rem; color: #b91c1c;">Zone sensible</h2>
    <p style="color: var(--muted); font-size: 0.88rem; margin: 0 0 1rem;">
        La suppression retire définitivement ce contenu (y compris commentaires). Cette action ne peut pas être annulée.
    </p>
    <form method="post" action="{{ path('app_content_delete', {id: content.id}) }}" onsubmit="return confirm('Supprimer définitivement ce contenu ?\\n\\nCette action est irréversible.');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ content.id) }}">
        <input type="hidden" name="_return_to" value="{{ returnTo|default(path('app_calendar')) }}">
        <button type="submit" class="btn btn-danger">Supprimer ce contenu</button>
    </form>
</section>
{% endblock %}
