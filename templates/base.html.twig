<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Gestion des contenus{% endblock %} | Osmose</title>
    {% block stylesheets %}
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700&display=swap');
            :root {
                --bg: #f1f5f9;
                --text: #0f172a;
                --topbar-bg: #ffffff;
                --topbar-border: #e2e8f0;
                --card-bg: #ffffff;
                --card-border: #e2e8f0;
                --muted: #475569;
                --input-bg: #ffffff;
                --input-border: #dbe1ea;
                --sidebar-bg: #140b2e;
                --sidebar-text: #cbd5e1;
                --sidebar-hover: #27124f;
                --sidebar-active: #4c1d95;
            }
            body.theme-dark {
                --bg: #0b0f1a;
                --text: #f8fafc;
                --topbar-bg: #111827;
                --topbar-border: #253047;
                --card-bg: #141b2b;
                --card-border: #253047;
                --muted: #cbd5e1;
                --input-bg: #10182a;
                --input-border: #334155;
                --sidebar-bg: #07040f;
                --sidebar-text: #cbd5e1;
                --sidebar-hover: #2f1b5f;
                --sidebar-active: #5b21b6;
            }
            * { box-sizing: border-box; }
            body {
                font-family: "Public Sans", system-ui, -apple-system, sans-serif;
                margin: 0;
                background: var(--bg);
                color: var(--text);
            }
            .layout { display: flex; min-height: 100vh; }
            .sidebar {
                width: 260px;
                background: var(--sidebar-bg);
                color: var(--sidebar-text);
                padding: 1rem 0.75rem;
                box-shadow: 2px 0 18px rgba(20, 11, 46, 0.28);
            }
            .brand {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.5rem 0.75rem 1rem;
                margin-bottom: 0.6rem;
                border-bottom: 1px solid rgba(148, 163, 184, 0.2);
            }
            .brand img { width: 150px; height: auto; object-fit: contain; }
            .brand strong { font-size: 1rem; color: #fff; }
            .sidebar a {
                display: block;
                padding: 0.65rem 0.8rem;
                color: var(--sidebar-text);
                text-decoration: none;
                border-radius: 0.55rem;
                margin-bottom: 0.2rem;
            }
            .sidebar a:hover { background: var(--sidebar-hover); color: #fff; }
            .sidebar a.active { background: var(--sidebar-active); color: #fff; }
            .sidebar h3 {
                padding: 0 0.8rem;
                font-size: 0.74rem;
                letter-spacing: 0.04em;
                text-transform: uppercase;
                color: #94a3b8;
                margin: 1rem 0 0.5rem;
            }
            .sidebar .divider {
                border: 0;
                border-top: 1px solid rgba(148, 163, 184, 0.2);
                margin: 0.9rem 0.8rem;
            }
            .main { flex: 1; min-width: 0; }
            .topbar {
                background: var(--topbar-bg);
                border-bottom: 1px solid var(--topbar-border);
                padding: 1rem 1.5rem;
                display: flex;
                justify-content: space-between;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 10;
            }
            .topbar .title { font-weight: 600; font-size: 1rem; color: var(--text); }
            .topbar-actions { display: flex; align-items: center; gap: 0.6rem; }
            .topbar-btn {
                border: 1px solid var(--card-border);
                background: var(--card-bg);
                color: var(--text);
                border-radius: 8px;
                padding: 0.4rem 0.55rem;
                cursor: pointer;
                font-size: 0.86rem;
            }
            .user-dropdown { position: relative; }
            .user-dropdown-menu {
                display: none;
                position: absolute;
                right: 0;
                top: calc(100% + 8px);
                min-width: 190px;
                background: var(--card-bg);
                border: 1px solid var(--card-border);
                border-radius: 10px;
                padding: 0.4rem;
                box-shadow: 0 12px 30px rgba(2, 6, 23, 0.2);
            }
            .user-dropdown.open .user-dropdown-menu { display: block; }
            .user-dropdown-menu a {
                display: block;
                text-decoration: none;
                color: var(--text);
                padding: 0.5rem 0.6rem;
                border-radius: 8px;
                font-size: 0.86rem;
            }
            .user-dropdown-menu a:hover { background: var(--sidebar-hover); color: #fff; }
            .page-content { padding: 1.5rem; }
            .flash-success, .flash-error {
                padding: 0.8rem 0.9rem;
                border-radius: 0.6rem;
                margin-bottom: 1rem;
                border: 1px solid transparent;
            }
            .flash-success { background: #ecfdf3; color: #166534; border-color: #bbf7d0; }
            .flash-error { background: #fef2f2; color: #991b1b; border-color: #fecaca; }
            .btn {
                display: inline-block;
                padding: 0.5rem 0.9rem;
                background: #5b21b6;
                color: #fff;
                border: none;
                border-radius: 0.5rem;
                cursor: pointer;
                text-decoration: none;
                font-size: 0.88rem;
                font-weight: 500;
            }
            .btn:hover { background: #4c1d95; }
            .btn-danger { background: #dc2626; }
            .btn-danger:hover { background: #b91c1c; }
            .btn-sm { padding: 0.34rem 0.62rem; font-size: 0.78rem; }
            form label { display: block; margin-bottom: 0.3rem; font-weight: 500; color: #334155; }
            form input[type="text"], form input[type="email"], form input[type="password"], form input[type="number"], form select, form textarea {
                width: 100%;
                max-width: 400px;
                padding: 0.55rem 0.6rem;
                margin-bottom: 1rem;
                border: 1px solid var(--input-border);
                border-radius: 0.5rem;
                background: var(--input-bg);
                color: var(--text);
            }
            .status-badge { display: inline-block; padding: 0.25rem 0.5rem; border-radius: 999px; font-size: 0.77rem; font-weight: 600; }
            .status-gray { background: #95a5a6; color: white; }
            .status-red { background: #e74c3c; color: white; }
            .status-orange { background: #e67e22; color: white; }
            .status-yellow { background: #f1c40f; color: #333; }
            .status-lightgreen { background: #2ecc71; color: white; }
            .status-green { background: #27ae60; color: white; }
            .status-taupe { background: #8b7d70; color: #fff; }
            .status-canard { background: #0f6b6f; color: #fff; }
            .status-violet { background: #6d28d9; color: #fff; }
            .status-bleu-nuit { background: #1e3a8a; color: #fff; }
            .status-ardoise { background: #475569; color: #fff; }
            .status-sauge { background: #7c9a92; color: #fff; }
            .status-menthe { background: #34d399; color: #0f172a; }
            .status-moutarde { background: #cfa500; color: #1f2937; }
            .status-corail { background: #fb7185; color: #fff; }
            .status-framboise { background: #be185d; color: #fff; }
            .status-rose-poudre { background: #f9a8d4; color: #5b2146; }
            .status-fuchsia { background: #d946ef; color: #fff; }
            h1 { margin-top: 0; margin-bottom: 1rem; font-size: 1.45rem; }
            table { background: var(--card-bg); border-radius: 0.75rem; }
            /* Interrupteur (sous-titres, etc.) */
            .toggle-switch {
                position: relative;
                display: inline-flex;
                align-items: center;
                cursor: pointer;
                user-select: none;
                vertical-align: middle;
            }
            .toggle-switch input {
                position: absolute;
                opacity: 0;
                width: 0;
                height: 0;
            }
            .toggle-switch-ui {
                width: 48px;
                height: 26px;
                background: #cbd5e1;
                border-radius: 999px;
                position: relative;
                transition: background 0.2s ease;
                flex-shrink: 0;
            }
            body.theme-dark .toggle-switch-ui { background: #475569; }
            .toggle-switch-ui::after {
                content: '';
                position: absolute;
                width: 20px;
                height: 20px;
                border-radius: 50%;
                background: #fff;
                top: 3px;
                left: 4px;
                box-shadow: 0 1px 3px rgba(15, 23, 42, 0.25);
                transition: transform 0.2s ease;
            }
            .toggle-switch input:checked + .toggle-switch-ui {
                background: #5b21b6;
            }
            .toggle-switch input:checked + .toggle-switch-ui::after {
                transform: translateX(20px);
            }
            .toggle-switch:focus-within .toggle-switch-ui {
                outline: 2px solid #a78bfa;
                outline-offset: 2px;
            }
            .subtitles-field-row {
                display: flex;
                align-items: center;
                gap: 0.85rem;
                margin-bottom: 1rem;
                flex-wrap: wrap;
            }
            .subtitles-field-row label.field-label {
                font-weight: 500;
                color: #334155;
                margin: 0;
            }
            body.theme-dark .subtitles-field-row label.field-label { color: #e2e8f0; }
        </style>
    {% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body data-turbo="false">
    <div class="layout">
        <nav class="sidebar">
            <div class="brand">
                <img src="{{ asset('logo-site-blanc.svg') }}" alt="Logo Osmose Marketing">
            </div>
            <h3>Navigation</h3>
            <a href="{{ path('app_dashboard') }}" class="{{ app.request.attributes.get('_route') in ['app_dashboard', 'app_home'] ? 'active' : '' }}">Dashboard</a>
            <a href="{{ path('app_calendar') }}" class="{{ app.request.attributes.get('_route') == 'app_calendar' ? 'active' : '' }}">Calendrier des contenus</a>
            <a href="{{ path('app_videos_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_videos_' ? 'active' : '' }}">Vidéos</a>
            <a href="{{ path('app_derush_index') }}" class="{{ app.request.attributes.get('_route') == 'app_derush_index' ? 'active' : '' }}">Dérush vidéo</a>
            <a href="{{ path('app_clients_table') }}" class="{{ app.request.attributes.get('_route') == 'app_clients_table' ? 'active' : '' }}">Clients sous gestion</a>
            <h3>Admin</h3>
            <a href="{{ path('app_admin_cm_index') }}">Community Managers</a>
            <a href="{{ path('app_admin_client_index') }}">Clients</a>
            {% if 'ROLE_ADMIN' in app.user.roles %}
                <a href="{{ path('app_admin_user_index') }}">Utilisateurs</a>
            {% endif %}
            <a href="{{ path('app_admin_status_format_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_admin_status_' or app.request.attributes.get('_route') starts with 'app_admin_format_' or app.request.attributes.get('_route') == 'app_admin_status_format_index' ? 'active' : '' }}">Statuts et formats</a>
            <hr class="divider">
        </nav>
        <main class="main">
            <header class="topbar">
                <div class="title">Dashboard Contenu</div>
                <div class="topbar-actions">
                    <button id="themeToggle" type="button" class="topbar-btn" title="Changer le theme">Lumiere</button>
                    {% if app.user %}
                        <div class="user-dropdown" id="userDropdown">
                            <button type="button" class="topbar-btn">{{ app.user.userIdentifier }}</button>
                            <div class="user-dropdown-menu">
                                <a href="{{ path('app_profile_redirect') }}">Modifier mon profil</a>
                                <a href="{{ path('app_logout') }}">Deconnexion</a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </header>
            <div class="page-content">
                {% for message in app.flashes('success') %}
                    <div class="flash-success">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="flash-error">{{ message }}</div>
                {% endfor %}
                {% block body %}{% endblock %}
            </div>
        </main>
    </div>
    <script>
        (function () {
            var body = document.body;
            var savedTheme = localStorage.getItem('contenu-theme');
            if (savedTheme === 'dark') {
                body.classList.add('theme-dark');
            }

            var themeBtn = document.getElementById('themeToggle');
            if (themeBtn) {
                var updateThemeLabel = function () {
                    themeBtn.textContent = body.classList.contains('theme-dark') ? 'Sombre' : 'Lumiere';
                };
                updateThemeLabel();
                themeBtn.addEventListener('click', function () {
                    body.classList.toggle('theme-dark');
                    localStorage.setItem('contenu-theme', body.classList.contains('theme-dark') ? 'dark' : 'light');
                    updateThemeLabel();
                });
            }

            var userDropdown = document.getElementById('userDropdown');
            if (userDropdown) {
                var button = userDropdown.querySelector('button');
                button.addEventListener('click', function (event) {
                    event.stopPropagation();
                    userDropdown.classList.toggle('open');
                });
                document.addEventListener('click', function () {
                    userDropdown.classList.remove('open');
                });
            }
        })();
    </script>
</body>
</html>
