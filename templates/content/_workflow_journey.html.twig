{% if workflow_journey is not empty %}
    <section class="workflow-journey" style="margin: 1rem 0 1.25rem; padding: 0.85rem 1rem; background: var(--bg); border-radius: 10px; border: 1px solid var(--card-border);">
        <h3 style="margin: 0 0 0.65rem; font-size: 0.92rem; font-weight: 700;">Parcours</h3>
        <ol style="margin: 0; padding-left: 1.15rem; display: grid; gap: 0.35rem; font-size: 0.86rem;">
            {% for entry in workflow_journey %}
                <li>
                    <strong>{{ entry.label }}</strong>
                    {% if entry.detail %}
                        <span style="color: var(--muted);"> — {{ entry.detail }}</span>
                    {% endif %}
                    <div style="color: var(--muted); font-size: 0.8rem;">
                        {{ entry.createdAt|date('d/m/Y H:i') }}
                        {% if entry.userName %} · {{ entry.userName }}{% endif %}
                    </div>
                </li>
            {% endfor %}
        </ol>
    </section>
{% endif %}
